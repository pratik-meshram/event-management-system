# ======================

# Root .gitignore (MERN)

# ======================

# ======================

# Logs

# ======================

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ======================

# Dependencies

# ======================

node_modules/
client/node_modules/
server/node_modules/

# ======================

# Environment files

# ======================

.env
.env.*
client/.env
server/.env
!.env.example

# ======================

# Build folders

# ======================

dist/
build/
client/dist/
client/build/
server/dist/

# ======================

# Vite cache (frontend)

# ======================

client/.vite/
vite.config.ts.timestamp-*
vite.config.js.timestamp-*

# ======================

# Uploads (Multer backend)

# ======================

server/uploads/
server/public/uploads/

# ======================

# Database files

# ======================

*.sqlite
*.sqlite3
*.db

# ======================

# Cache / temp

# ======================

.cache/
.temp/
tmp/
temp/
.eslintcache

# ======================

# Test coverage

# ======================

coverage/

# ======================

# OS files

# ======================

.DS_Store
Thumbs.db
Desktop.ini

# ======================

# IDE / Editor

# ======================

.vscode/*
!.vscode/extensions.json
.idea/

# ======================

# Optional lock files

# ======================

# package-lock.json

# yarn.lock

# pnpm-lock.yaml
